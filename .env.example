# DartLunch — proxy (server) environment.
# These are read by the Node proxy ONLY. They are never bundled into the browser.

# By default DartLunch uses FREE OpenStreetMap data (Overpass) — no key needed.
# OPTIONAL: set a Google Places API key for richer data (ratings/price/open-now).
# When set, the proxy uses Google instead of OpenStreetMap. Server-side only.
GOOGLE_PLACES_KEY=

# Port the proxy listens on (the Vite dev server proxies /api here).
PORT=8787

# Allowed CORS origin for the frontend (dev default below).
FRONTEND_ORIGIN=http://localhost:5173

# Local-dev convenience: set to 1 to serve sample restaurants WITHOUT a Google key,
# so you can play before setting up Google Cloud. Off by default. Never enable in prod.
DARTLUNCH_MOCK=
